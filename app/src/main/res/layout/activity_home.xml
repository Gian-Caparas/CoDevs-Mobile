<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#4A5D3F"><?xml version="1.0" encoding="utf-8"?>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#4A5D3F"> <!-- Dark Olive Green Background -->

        <!-- SCROLLABLE CONTENT AREA -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <!-- We add bottom padding here so the bottom content clears the sticky nav bar -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="110dp">

                <!-- Top Abstract Graphic Placeholder -->
                <ImageView
                    android:layout_width="250dp"
                    android:layout_height="250dp"
                    android:alpha="0.35"
                    android:scaleType="fitEnd"
                    android:src="@drawable/logo"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- Top Bar: Profile & Search -->
                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/profileImage"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:layout_marginStart="24dp"
                    android:layout_marginTop="32dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/profile_placeholder"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:shapeAppearanceOverlay="@style/CircleImageView"
                    app:strokeColor="#C5D8B6"
                    app:strokeWidth="1dp" />

                <EditText
                    android:id="@+id/searchEditText"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="24dp"
                    android:background="@drawable/search_bg"
                    android:hint="Search"
                    android:paddingHorizontal="24dp"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#99FFFFFF"
                    app:layout_constraintBottom_toBottomOf="@+id/profileImage"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/profileImage"
                    app:layout_constraintTop_toTopOf="@+id/profileImage" />

                <!-- Welcome Greeting -->
                <TextView
                    android:id="@+id/tvWelcome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="Welcome,"
                    android:textColor="#C5D8B6"
                    android:textSize="40sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="@+id/profileImage"
                    app:layout_constraintTop_toBottomOf="@+id/profileImage" />

                <TextView
                    android:id="@+id/tvName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Guest!"
                    android:textColor="#C5D8B6"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="@+id/tvWelcome"
                    app:layout_constraintTop_toBottomOf="@+id/tvWelcome" />

                <!-- Lower Light Green Container -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:background="@drawable/main_content_bg"
                    android:paddingHorizontal="24dp"
                    android:paddingTop="24dp"
                    android:paddingBottom="24dp"
                    app:layout_constraintTop_toBottomOf="@+id/tvName">

                    <!-- Top Banner -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/bannerCard"
                        android:layout_width="match_parent"
                        android:layout_height="180dp"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="8dp"
                        app:layout_constraintTop_toTopOf="parent">

                        <ImageView
                            android:layout_width="360dp"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/ic_launcher_background" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="bottom"
                            android:background="#44000000"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Anniversary Sale!"
                                android:textColor="#FFFFFF"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Get service discounts up to 39%!"
                                android:textColor="#FFFFFF"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Thin Divider -->
                    <View
                        android:id="@+id/divider"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="24dp"
                        android:background="#7B8D6D"
                        app:layout_constraintTop_toBottomOf="@+id/bannerCard" />

                    <!-- Grid: Tall Fridge Card (Left) -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardFridge"
                        android:layout_width="0dp"
                        android:layout_height="250dp"
                        android:layout_marginTop="24dp"
                        android:layout_marginEnd="8dp"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="6dp"
                        app:layout_constraintEnd_toStartOf="@+id/cardTv"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/divider">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/ic_launcher_background" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="bottom"
                            android:padding="16dp"
                            android:text="Fridges"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold" />
                    </androidx.cardview.widget.CardView>

                    <!-- Grid: Wide TV Card (Right Top) -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardTv"
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_marginStart="8dp"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="6dp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@+id/cardFridge"
                        app:layout_constraintTop_toTopOf="@+id/cardFridge">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/ic_launcher_background" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="bottom"
                            android:padding="12dp"
                            android:text="TVs"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold" />
                    </androidx.cardview.widget.CardView>

                    <!-- Grid: Text Below TV (Right Bottom) -->
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="pre-owned &amp;\nrepaired\nappliances"
                        android:textColor="#4A5D3F"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="@+id/cardTv"
                        app:layout_constraintStart_toStartOf="@+id/cardTv"
                        app:layout_constraintTop_toBottomOf="@+id/cardTv" />

                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardAircondition"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:layout_marginTop="15dp"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="6dp"
                        app:layout_constraintTop_toBottomOf="@+id/cardFridge">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/ic_launcher_background" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="bottom"
                            android:padding="12dp"
                            android:text="Airconditions"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold" />
                    </androidx.cardview.widget.CardView>



                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.core.widget.NestedScrollView>



        <!-- STICKY FLOATING BOTTOM NAVIGATION (Glass Effect) -->
        <!-- Placed outside the ScrollView and pinned to the bottom of the screen -->
        <LinearLayout
            android:id="@+id/bottomNav"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:background="@drawable/bg_nav_bar"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingBottom="10dp"
            android:weightSum="4"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageButton
                android:id="@+id/btnMenu"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:scaleType="centerInside"
                android:src="@drawable/menu" />

            <ImageButton
                android:id="@+id/btnHome"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:scaleType="centerInside"
                android:src="@drawable/home" />

            <ImageButton
                android:id="@+id/btnShop"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:scaleType="centerInside"
                android:src="@drawable/shop" />

            <ImageButton
                android:id="@+id/btnEmail"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:scaleType="centerInside"
                android:src="@drawable/email" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout></androidx.constraintlayout.widget.ConstraintLayout>