<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#B2BE91">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@+id/navBarFragment"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp">

            <TextView
                android:id="@+id/tvAccountDetails"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Account Details"
                android:textColor="#3F462A"
                android:textSize="24sp"
                android:textStyle="bold"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/profileImage"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginTop="24dp"
                android:padding="2dp"
                android:src="@drawable/profile_placeholder"
                app:layout_constraintWidth_percent="0.5"
                app:layout_constraintDimensionRatio="1:1"
                app:layout_constraintTop_toBottomOf="@id/tvAccountDetails"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:shapeAppearanceOverlay="@style/CircleImage"
                app:strokeColor="#3F462A"
                app:strokeWidth="1dp" />

            <LinearLayout
                android:id="@+id/rowNames"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:orientation="horizontal"
                app:layout_constraintTop_toBottomOf="@id/profileImage">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Firstname"
                        android:textStyle="bold"
                        android:textColor="#3F462A"/>

                    <EditText
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:background="@drawable/outline_field_bg"
                        android:paddingStart="12dp"
                        android:text="Gian Joebert"
                        android:textSize="14sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lastname"
                        android:textStyle="bold"
                        android:textColor="#3F462A"/>

                    <EditText
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:background="@drawable/outline_field_bg"
                        android:paddingStart="12dp"
                        android:text="Caparas"
                        android:textSize="14sp"/>
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/lblEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Email Address"
                android:textStyle="bold"
                android:textColor="#3F462A"
                app:layout_constraintTop_toBottomOf="@id/rowNames"/>

            <EditText
                android:id="@+id/fieldEmail"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/outline_field_bg"
                android:paddingStart="12dp"
                android:text="gianjoebert.caparas@cit.edu"
                android:textSize="14sp"
                app:layout_constraintTop_toBottomOf="@id/lblEmail"/>

            <TextView
                android:id="@+id/lblAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Home Address"
                android:textStyle="bold"
                android:textColor="#3F462A"
                app:layout_constraintTop_toBottomOf="@id/fieldEmail"/>

            <EditText
                android:id="@+id/fieldAddress"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/outline_field_bg"
                android:paddingStart="12dp"
                android:text="Tungkil, Minglanilla, Cebu, Philippines"
                android:textSize="14sp"
                app:layout_constraintTop_toBottomOf="@id/lblAddress"/>

            <View
                android:id="@+id/profileLineDivider"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="24dp"
                android:background="#3F462A"
                app:layout_constraintTop_toBottomOf="@id/fieldAddress"/>

            <Button
                android:id="@+id/btnTxHistory"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="24dp"
                android:backgroundTint="#7B8A50"
                android:text="Transaction History"
                android:textAllCaps="false"
                android:textColor="#E6EBD6"
                app:cornerRadius="15dp"
                app:layout_constraintTop_toBottomOf="@id/profileLineDivider"/>

            <Button
                android:id="@+id/btnReportIssue"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="16dp"
                android:backgroundTint="#7B8A50"
                android:text="Report Issues"
                android:textAllCaps="false"
                android:textColor="#E6EBD6"
                app:cornerRadius="15dp"
                app:layout_constraintTop_toBottomOf="@id/btnTxHistory"/>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

    <fragment
        android:id="@+id/navBarFragment"
        android:name="com.example.codevs.NavBarFragment"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        tools:layout="@layout/fragment_nav_bar"/>

</androidx.constraintlayout.widget.ConstraintLayout>