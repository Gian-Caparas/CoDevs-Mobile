<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#3F462A"
    android:fillViewport="true"
    tools:context=".SignIn">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="60dp"
            android:paddingBottom="30dp">

            <ImageView
                android:id="@+id/logo"
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:contentDescription="App Logo"
                android:src="@drawable/logo" />

            <TextView
                android:id="@+id/tvWelcome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Welcome Back!"
                android:textColor="#B0BC8C"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/loginContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_login_card"
            android:orientation="vertical"
            android:paddingHorizontal="32dp"
            android:paddingTop="30dp"
            android:paddingBottom="30dp">

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:background="@drawable/outline_field_bg"
                android:hint="Enter your email"
                android:paddingStart="20dp"
                android:textColorHint="#3F462A" />

            <EditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/outline_field_bg"
                android:hint="Enter your password"
                android:inputType="textPassword"
                android:paddingStart="20dp"
                android:textColorHint="#3F462A" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">

                <CheckBox
                    android:id="@+id/cbRemember"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="#3F462A"
                    android:text="Remember"
                    android:textColor="#3F462A"
                    android:textSize="16sp"/>

                <TextView
                    android:id="@+id/tvForgot"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:text="Forgot Password?"
                    android:textColor="#3F462A"
                    android:textSize="16sp"
                    android:textStyle="bold"/>
            </RelativeLayout>

            <Button
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="12dp"
                android:backgroundTint="#7B8A50"
                android:text="Login"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:textColor="#3F462A"
                app:cornerRadius="20dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:orientation="horizontal">
                <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" android:background="#3F462A" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:paddingHorizontal="10dp" android:text="Or" android:textColor="#3F462A" android:textSize="16sp"/>
                <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" android:background="#3F462A" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGoogle"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="14dp"
                android:text="Google"
                android:textSize="16sp"
                android:textAllCaps="false"
                android:textColor="#000000"
                app:cornerRadius="20dp"
                app:icon="@drawable/google_button"
                app:iconGravity="textStart"
                app:iconPadding="12dp"
                app:iconTint="@null"
                app:strokeColor="#3F462A" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFacebook"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="10dp"
                android:text="Facebook"
                android:textSize="16sp"
                android:textAllCaps="false"
                android:textColor="#000000"
                app:cornerRadius="20dp"
                app:icon="@drawable/facebook_button"
                app:iconGravity="textStart"
                app:iconPadding="12dp"
                app:iconTint="@null"
                app:strokeColor="#3F462A" />

            <TextView
                android:id="@+id/tvSignUpLink"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:text="Don’t have an account? Sign up"
                android:textSize="15sp"
                android:textColor="#3F462A" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>