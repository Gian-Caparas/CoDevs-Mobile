<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#3F462A"
    android:fillViewport="true"
    tools:context=".SignUp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="60dp"
            android:paddingBottom="30dp">

            <ImageView
                android:id="@+id/logo"
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:contentDescription="App Logo"
                android:src="@drawable/logo" />

            <TextView
                android:id="@+id/tvWelcome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Ready to Serve!"
                android:textColor="#B0BC8C"
                android:textSize="26sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/loginContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_login_card"
            android:orientation="vertical"
            android:paddingHorizontal="32dp"
            android:paddingTop="32dp"
            android:paddingBottom="40dp">

            <EditText
                android:id="@+id/etUserName"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:background="@drawable/outline_field_bg"
                android:hint="Enter your username"
                android:paddingStart="20dp"
                android:textColorHint="#3F462A" />

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/outline_field_bg"
                android:hint="Enter your email"
                android:inputType="textEmailAddress"
                android:paddingStart="20dp"
                android:textColorHint="#3F462A" />

            <EditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/outline_field_bg"
                android:hint="Enter your password"
                android:inputType="textPassword"
                android:paddingStart="20dp"
                android:textColorHint="#3F462A" />

            <Button
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="24dp"
                android:backgroundTint="#7B8A50"
                android:text="Sign up"
                android:textAllCaps="false"
                android:textColor="#3F462A"
                android:textSize="18sp"
                android:textStyle="bold"
                app:cornerRadius="20dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center"
                android:orientation="horizontal">
                <View android:layout_width="0dp" android:layout_height="1.5dp" android:layout_weight="1" android:background="#3F462A" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:paddingHorizontal="10dp" android:text="Or" android:textColor="#3F462A" android:textSize="16sp"/>
                <View android:layout_width="0dp" android:layout_height="1.5dp" android:layout_weight="1" android:background="#3F462A" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGoogle"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="16dp"
                android:text="Google"
                android:textSize="16sp"
                android:textAllCaps="false"
                android:textColor="#000000"
                app:cornerRadius="20dp"
                app:icon="@drawable/google_button"
                app:iconGravity="textStart"
                app:iconPadding="12dp"
                app:iconTint="@null"
                app:strokeColor="#3F462A"  />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFacebook"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="10dp"
                android:text="Facebook"
                android:textSize="16sp"
                android:textAllCaps="false"
                android:textColor="#000000"
                app:cornerRadius="20dp"
                app:icon="@drawable/facebook_button"
                app:iconGravity="textStart"
                app:iconPadding="12dp"
                app:iconTint="@null"
                app:strokeColor="#3F462A" />

            <TextView
                android:id="@+id/tvSignInLink"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:text="Already have an account? Sign in"
                android:textSize="15sp"
                android:textColor="#3F462A" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>