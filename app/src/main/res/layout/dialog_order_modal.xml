<?xml version="1.0" encoding="utf-8"?>
<!-- dialog_order_modal.xml — placed in res/layout/ -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/main_content_bg"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- Product Image (rounded card) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/modalProductImageCard"
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp">

        <ImageView
            android:id="@+id/modalProductImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerInside"
            android:src="@drawable/ic_launcher_background" />

    </androidx.cardview.widget.CardView>

    <!-- Product Info -->
    <TextView
        android:id="@+id/modalProductName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Product: Aircon"
        android:textColor="#3A4E2A"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/modalProductPrice"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Price: ₱ 29,500"
        android:textColor="#3A4E2A"
        android:textSize="14sp"
        android:layout_marginBottom="12dp" />

    <!-- Quantity Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Quantity:"
            android:textColor="#3A4E2A"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btnDecreaseQty"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="12dp"
            android:backgroundTint="#4A5D3F"
            android:text="−"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:padding="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            app:cornerRadius="8dp" />

        <TextView
            android:id="@+id/tvQuantity"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1"
            android:textColor="#3A4E2A"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginHorizontal="14dp" />

        <Button
            android:id="@+id/btnIncreaseQty"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:backgroundTint="#4A5D3F"
            android:text="+"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:padding="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            app:cornerRadius="8dp" />

    </LinearLayout>

    <!-- Total Cost -->
    <TextView
        android:id="@+id/modalTotalCost"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Total cost: ₱ 29,500"
        android:textColor="#3A4E2A"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginBottom="20dp" />

    <!-- Confirm Button -->
    <Button
        android:id="@+id/btnConfirmOrder"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:backgroundTint="#4A5D3F"
        android:text="confirm order"
        android:textAllCaps="false"
        android:textColor="#C5D8B6"
        android:textSize="15sp"
        android:textStyle="bold"
        app:cornerRadius="24dp" />

</LinearLayout>