<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#D0E3C2"
    tools:context=".Search">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/stickyTopBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#4A5D3F"
        android:paddingBottom="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <EditText
            android:id="@+id/searchEditText"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/search_bg"
            android:hint="Search"
            android:paddingHorizontal="24dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#99FFFFFF"
            app:layout_constraintBottom_toBottomOf="@+id/profileImage"
            app:layout_constraintEnd_toStartOf="@+id/profileImage"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/profileImage" />

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/profileImage"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_marginEnd="24dp"
            android:layout_marginTop="32dp"
            android:scaleType="centerCrop"
            android:src="@drawable/profile_placeholder"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:shapeAppearanceOverlay="@style/CircleImageView"
            app:strokeColor="#C5D8B6"
            app:strokeWidth="1dp" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@+id/navBarFragmentSearch"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/stickyTopBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="16dp">

            <LinearLayout
                android:id="@+id/recentSearchSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Recent Search"
                    android:textColor="#555555"
                    android:textSize="13sp"
                    android:layout_marginBottom="10dp" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="start">

                        <TextView
                            android:id="@+id/chipAircon"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/chip_bg"
                            android:paddingHorizontal="14dp"
                            android:paddingVertical="6dp"
                            android:text="Split-type Aircon"
                            android:textColor="#4A5D3F"
                            android:textSize="12sp"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:id="@+id/chipSmartTv"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/chip_bg"
                            android:paddingHorizontal="14dp"
                            android:paddingVertical="6dp"
                            android:text="Smart TV"
                            android:textColor="#4A5D3F"
                            android:textSize="12sp"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:id="@+id/chipRef"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/chip_bg"
                            android:paddingHorizontal="14dp"
                            android:paddingVertical="6dp"
                            android:text="Refrigerator"
                            android:textColor="#4A5D3F"
                            android:textSize="12sp"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:id="@+id/chipRiceCooker"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/chip_bg"
                            android:paddingHorizontal="14dp"
                            android:paddingVertical="6dp"
                            android:text="Rice Cooker"
                            android:textColor="#4A5D3F"
                            android:textSize="12sp" />
                    </LinearLayout>
                </HorizontalScrollView>
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Search Suggestions"
                android:textColor="#555555"
                android:textSize="13sp"
                android:paddingHorizontal="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="8dp" />

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:rowCount="2"
                android:paddingHorizontal="12dp"
                android:useDefaultMargins="true">

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardPanasonic"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Panasonic"
                            android:textColor="#003087"
                            android:textStyle="bold"
                            android:textSize="12sp"
                            android:layout_marginBottom="6dp" />

                        <ImageView
                            android:id="@+id/imgPanasonicAircon"
                            android:layout_width="100dp"
                            android:layout_height="80dp"
                            android:scaleType="centerInside"
                            android:src="@drawable/ic_launcher_background" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Panasonic Aircon"
                            android:textColor="#333333"
                            android:textSize="13sp"
                            android:gravity="center"
                            android:layout_marginTop="6dp" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardHisense"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Hisense"
                            android:textColor="#EF3340"
                            android:textStyle="bold"
                            android:textSize="12sp"
                            android:layout_marginBottom="6dp" />

                        <ImageView
                            android:id="@+id/imgHisenseTv"
                            android:layout_width="100dp"
                            android:layout_height="80dp"
                            android:scaleType="centerInside"
                            android:src="@drawable/ic_launcher_background" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Hisense Smart TV"
                            android:textColor="#333333"
                            android:textSize="13sp"
                            android:gravity="center"
                            android:layout_marginTop="6dp" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardTcl"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TCL"
                            android:textColor="#1B4D8E"
                            android:textStyle="bold"
                            android:textSize="12sp"
                            android:layout_marginBottom="6dp" />

                        <ImageView
                            android:id="@+id/imgTclWasher"
                            android:layout_width="100dp"
                            android:layout_height="80dp"
                            android:scaleType="centerInside"
                            android:src="@drawable/ic_launcher_background" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TCL Washing Machine"
                            android:textColor="#333333"
                            android:textSize="13sp"
                            android:gravity="center"
                            android:layout_marginTop="6dp" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardCondura"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="CONDURA"
                            android:textColor="#222222"
                            android:textStyle="bold"
                            android:textSize="12sp"
                            android:layout_marginBottom="6dp" />

                        <ImageView
                            android:id="@+id/imgConduraRef"
                            android:layout_width="100dp"
                            android:layout_height="80dp"
                            android:scaleType="centerInside"
                            android:src="@drawable/ic_launcher_background" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Condura Refrigerator"
                            android:textColor="#333333"
                            android:textSize="13sp"
                            android:gravity="center"
                            android:layout_marginTop="6dp" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </GridLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <fragment
        android:id="@+id/navBarFragmentSearch"
        android:name="com.example.codevs.NavBarFragment"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        tools:layout="@layout/fragment_nav_bar" />

</androidx.constraintlayout.widget.ConstraintLayout>