<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#4A5D3F"
    tools:context=".Order">

    <!-- ── TOP BAR ── -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/topBarOrder"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#4A5D3F"
        android:paddingTop="36dp"
        android:paddingBottom="16dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <EditText
            android:id="@+id/searchEditTextOrder"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:background="@drawable/search_bg"
            android:hint="Search"
            android:inputType="text"
            android:paddingHorizontal="20dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#99FFFFFF"
            android:textSize="15sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/profileImageOrder"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/profileImageOrder"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="10dp"
            android:scaleType="centerCrop"
            android:src="@drawable/profile_placeholder"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:shapeAppearanceOverlay="@style/CircleImageView"
            app:strokeColor="#C5D8B6"
            app:strokeWidth="1dp" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ── SCROLLABLE CONTENT ── -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@+id/navBarFragmentOrder"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/topBarOrder">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── HERO SECTION (dark green) ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#4A5D3F"
                android:orientation="vertical"
                android:paddingHorizontal="24dp"
                android:paddingTop="8dp"
                android:paddingBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Shop"
                    android:textColor="#C5D8B6"
                    android:textSize="42sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="see our products and\nservices below!"
                    android:textColor="#A8C090"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- ── LIGHT GREEN CONTENT AREA ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#D0E3C2"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingTop="20dp"
                android:paddingBottom="20dp">

                <!-- PRODUCTS Header -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="products"
                    android:textColor="#3A4E2A"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <!-- ── PRODUCT CARD 1: Panasonic ── -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardProduct1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="12dp"
                        android:gravity="center_vertical">

                        <ImageView
                            android:id="@+id/imgProduct1"
                            android:layout_width="90dp"
                            android:layout_height="80dp"
                            android:scaleType="centerInside"
                            android:src="@drawable/ic_launcher_background" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:paddingStart="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Brand: Panasonic"
                                android:textColor="#333333"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Model: CW-U921JH"
                                android:textColor="#555555"
                                android:textSize="12sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Price: ₱ 29,500"
                                android:textColor="#333333"
                                android:textSize="12sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Ratings: ★★★★★"
                                android:textColor="#F5A623"
                                android:textSize="12sp" />

                            <Button
                                android:id="@+id/btnOrderProduct1"
                                android:layout_width="100dp"
                                android:layout_height="36dp"
                                android:layout_marginTop="8dp"
                                android:backgroundTint="#4A5D3F"
                                android:text="order"
                                android:textAllCaps="false"
                                android:textColor="#FFFFFF"
                                android:textSize="13sp"
                                app:cornerRadius="20dp" />

                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- ── PRODUCT CARD 2: Carrier ── -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardProduct2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="12dp"
                        android:gravity="center_vertical">

                        <ImageView
                            android:id="@+id/imgProduct2"
                            android:layout_width="90dp"
                            android:layout_height="80dp"
                            android:scaleType="centerInside"
                            android:src="@drawable/ic_launcher_background" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:paddingStart="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Brand: Carrier"
                                android:textColor="#333333"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Model: FP-53CKV030308"
                                android:textColor="#555555"
                                android:textSize="12sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Price: ₱ 39,500"
                                android:textColor="#333333"
                                android:textSize="12sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Ratings: ★★★★★"
                                android:textColor="#F5A623"
                                android:textSize="12sp" />

                            <Button
                                android:id="@+id/btnOrderProduct2"
                                android:layout_width="100dp"
                                android:layout_height="36dp"
                                android:layout_marginTop="8dp"
                                android:backgroundTint="#4A5D3F"
                                android:text="order"
                                android:textAllCaps="false"
                                android:textColor="#FFFFFF"
                                android:textSize="13sp"
                                app:cornerRadius="20dp" />

                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- ── PRODUCT CARD 3: Hitachi ── -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardProduct3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="12dp"
                        android:gravity="center_vertical">

                        <ImageView
                            android:id="@+id/imgProduct3"
                            android:layout_width="90dp"
                            android:layout_height="80dp"
                            android:scaleType="centerInside"
                            android:src="@drawable/ic_launcher_background" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:paddingStart="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Brand: Hitachi"
                                android:textColor="#333333"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Model: RAS-08HT"
                                android:textColor="#555555"
                                android:textSize="12sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Price: ₱ 40,500"
                                android:textColor="#333333"
                                android:textSize="12sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Ratings: ★★★★"
                                android:textColor="#F5A623"
                                android:textSize="12sp" />

                            <Button
                                android:id="@+id/btnOrderProduct3"
                                android:layout_width="100dp"
                                android:layout_height="36dp"
                                android:layout_marginTop="8dp"
                                android:backgroundTint="#4A5D3F"
                                android:text="order"
                                android:textAllCaps="false"
                                android:textColor="#FFFFFF"
                                android:textSize="13sp"
                                app:cornerRadius="20dp" />

                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- ── SERVICES DIVIDER ── -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#7B8D6D"
                    android:layout_marginBottom="16dp" />

                <!-- SERVICES Header -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Services"
                    android:textColor="#3A4E2A"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="tech solutions for your needs."
                    android:textColor="#5A6E4A"
                    android:textSize="13sp"
                    android:layout_marginBottom="12dp" />

                <!-- Services Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="We offer:"
                                android:textColor="#333333"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:layout_marginBottom="6dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="• Repairs\n• Software development\n• UI/UX Design"
                                android:textColor="#555555"
                                android:textSize="13sp"
                                android:layout_marginBottom="12dp" />

                            <Button
                                android:id="@+id/btnContactUs"
                                android:layout_width="wrap_content"
                                android:layout_height="36dp"
                                android:backgroundTint="#4A5D3F"
                                android:text="contact us now"
                                android:textAllCaps="false"
                                android:textColor="#FFFFFF"
                                android:textSize="12sp"
                                app:cornerRadius="20dp" />
                        </LinearLayout>

                        <ImageView
                            android:layout_width="90dp"
                            android:layout_height="90dp"
                            android:scaleType="centerCrop"
                            android:src="@drawable/ic_launcher_background"
                            android:layout_marginStart="12dp" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Services wide image -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_launcher_background" />

                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ── BOTTOM NAV BAR ── -->
    <fragment
        android:id="@+id/navBarFragmentOrder"
        android:name="com.example.codevs.NavBarFragment"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        tools:layout="@layout/fragment_nav_bar" />

</androidx.constraintlayout.widget.ConstraintLayout>